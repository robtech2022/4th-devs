# LLM API Configuration
OPENAI_API_KEY=your-openai-key-here
# OR use OpenRouter
# OPENROUTER_API_KEY=your-openrouter-key-here
# OPENROUTER_HTTP_REFERER=https://your-domain.com
# OPENROUTER_APP_NAME=logistics-proxy

# AI Provider (openai or openrouter)
AI_PROVIDER=openai

# Hub API Key (required)
AG3NTS_API_KEY=your-ag3nts-api-key-here

# Server Port (optional, default: 8080)
PORT=8080
